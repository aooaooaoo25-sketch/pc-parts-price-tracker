#!/bin/sh
# ─────────────────────────────────────────────────────────────
# 前後端零件資料同步檢查（待辦 #2 的強制保證）
# 若 index.html 的 DB 與後端 PARTS_DB 不一致，擋下本次 commit。
# 啟用方式（每個 clone 執行一次）： git config core.hooksPath hooks
# ─────────────────────────────────────────────────────────────
export PYTHONUTF8=1   # 專案路徑含中文，避免 Windows 下 python 路徑亂碼

if command -v python >/dev/null 2>&1; then
    PY=python
elif command -v py >/dev/null 2>&1; then
    PY=py
else
    echo "[pre-commit] 找不到 python，略過零件同步檢查。" >&2
    exit 0
fi

"$PY" tools/sync_parts.py --check
if [ $? -ne 0 ]; then
    echo "" >&2
    echo "[pre-commit] 前後端零件資料未同步，commit 已中止。" >&2
    echo "[pre-commit] 請先執行： $PY tools/sync_parts.py  然後重新 git add / commit。" >&2
    exit 1
fi
exit 0
