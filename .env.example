# 複製此檔為 .env 並填入真實值（.env 已被 .gitignore 忽略，不會提交）
# cp .env.example .env        (macOS / Linux)
# copy .env.example .env      (Windows)

# Anthropic API 金鑰（學校金鑰），程式啟用 python-dotenv 後讀取
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# eBay Browse API（海外參考價來源，EbayScraper 用；未設定則自動略過）
# 申請：https://developer.ebay.com/ → 建 App → 取 Production keyset
#   - EBAY_CLIENT_ID     = App ID (Client ID)
#   - EBAY_CLIENT_SECRET = Cert ID (Client Secret)
# 程式以 client_credentials 自動換取 OAuth token（約 2 小時，會自動續期）。
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
# 市場別（預設美國站）與 USD→TWD 換算匯率（預設 32）；eBay 報價為美金，入庫前換算為台幣。
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_TWD_RATE=32
